<view class="container">
  <view class="user-section" wx:if="{{hasUserInfo}}">
    <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    <text class="nickname">{{userInfo.nickName}}</text>
  </view>

  <view class="login-section" wx:else>
    <button class="login-btn" bindtap="getUserProfile">登录</button>
  </view>

  <view class="items-section" wx:if="{{hasUserInfo}}">
    <view class="section-title">我的记录</view>

    <view class="tabs">
      <view class="tab-item {{currentTab === 'on' ? 'active' : ''}}" data-tab="on" bindtap="onTabChange">
        <text>展示中</text>
        <text class="tab-count">{{onCount}}</text>
      </view>
      <view class="tab-item {{currentTab === 'off' ? 'active' : ''}}" data-tab="off" bindtap="onTabChange">
        <text>已隐藏</text>
        <text class="tab-count">{{offCount}}</text>
      </view>
    </view>

    <view class="item-list">
      <view class="item-card" wx:for="{{filteredItems}}" wx:key="_id">
        <view class="item-main">
          <image 
            wx:if="{{item.images && item.images.length > 0}}"
            class="item-image" 
            src="{{item.images[0]}}" 
            mode="aspectFill"
            lazy-load="{{true}}"
          ></image>
          <view wx:else class="item-image placeholder">
            <text>暂无图片</text>
          </view>
          <view class="item-info">
            <text class="item-title">{{item.title}}</text>
            <text class="item-value" wx:if="{{item.value}}">好物值：{{item.value}}</text>
          </view>
        </view>
        <view class="item-actions">
          <view 
            class="action-btn edit" 
            data-id="{{item._id}}" 
            catchtap="goToEdit"
          >
            编辑
          </view>
          <view 
            class="action-btn {{item.status === 'off' ? 'on-btn' : 'off-btn'}}" 
            data-id="{{item._id}}" 
            data-status="{{item.status}}"
            catchtap="toggleStatus"
          >
            {{item.status === 'off' ? '展示' : '隐藏'}}
          </view>
          <view class="action-btn delete" data-id="{{item._id}}" catchtap="deleteItem">
            删除
          </view>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{!loading && filteredItems.length === 0}}">
      <text class="empty-text">暂无{{currentTab === 'on' ? '展示中' : '已隐藏'}}的记录</text>
    </view>
  </view>

  <view class="admin-section" wx:if="{{isAdmin}}">
    <button class="admin-btn" bindtap="goToAdmin">管理后台</button>
  </view>

  <view class="version">
    <text>版本 2.0.0</text>
  </view>
</view>

<canvas canvas-id="shareCanvas" class="share-canvas" style="width: 300px; height: 400px; position: fixed; left: -9999px; top: -9999px;"></canvas>
