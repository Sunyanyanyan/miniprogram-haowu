.container {
  padding: 0;
  background-color: #F8F9FB;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.image-swiper {
  width: 100%;
  height: 600rpx;
}

.detail-image {
  width: 100%;
  height: 100%;
  background-color: #f0f0f0;
  object-fit: cover;
}

.info-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.title {
  flex: 1;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.share-btn {
  font-size: 26rpx;
  color: #9B59B6;
  padding: 12rpx 24rpx;
  background-color: #F8F9FB;
  border-radius: 24rpx;
}

.expire-tip {
  display: flex;
  align-items: center;
  background-color: #FFF5F0;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.expire-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.expire-text {
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: 500;
}

.tag-wrap {
  margin-bottom: 16rpx;
}

.item-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background-color: #F8F0FB;
  color: #9B59B6;
  font-size: 24rpx;
  border-radius: 6rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.info-label {
  font-size: 26rpx;
  color: #666;
}

.info-value {
  font-size: 26rpx;
  color: #333;
}

.info-value.highlight {
  color: #9B59B6;
  font-weight: 600;
  font-size: 32rpx;
}

.desc-section, .contact-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.contact-hidden {
  background-color: #F8F9FB;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
  color: #9B59B6;
  font-size: 28rpx;
}

.contact-info {
  background-color: #F8F9FB;
  padding: 24rpx;
  border-radius: 12rpx;
}

.contact-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 20rpx;
}

.contact-actions {
  display: flex;
  gap: 20rpx;
}

.contact-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background-color: #9B59B6;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.actions {
  margin: 20rpx 30rpx;
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.edit-btn {
  background: linear-gradient(135deg, #9B59B6 0%, #8E44AD 100%);
  color: #fff;
}

.on-btn {
  background-color: #4caf50;
  color: #fff;
}

.off-btn {
  background-color: #ff9800;
  color: #fff;
}

.delete-btn {
  background-color: #f44336;
  color: #fff;
}

.loading {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
}
