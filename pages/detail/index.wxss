.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.image-swiper {
  width: 100%;
  height: 600rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.detail-image {
  width: 100%;
  height: 100%;
  background-color: #f0f0f0;
}

.info-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.tag-wrap {
  margin-bottom: 16rpx;
}

.item-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background-color: #fff3e0;
  color: #FF6B35;
  font-size: 24rpx;
  border-radius: 6rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.info-label {
  font-size: 26rpx;
  color: #666;
}

.info-value {
  font-size: 26rpx;
  color: #333;
}

.info-value.highlight {
  color: #FF6B35;
  font-weight: 500;
}

.expire-info {
  font-size: 24rpx;
  color: #4caf50;
  margin-bottom: 16rpx;
}

.expire-info.expired {
  color: #f44336;
}

.meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  min-width: 80rpx;
  height: 40rpx;
}

.status.on {
  background-color: #e8f5e9;
  color: #4caf50;
}

.status.off {
  background-color: #ffebee;
  color: #f44336;
}

.desc-section, .contact-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.contact-hidden {
  background-color: #FF6B35;
  color: #fff;
  padding: 20rpx;
  border-radius: 8rpx;
  text-align: center;
}

.contact-show {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 20rpx;
}

.contact-info {
  background-color: #fff;
  padding: 24rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.contact-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.contact-actions {
  display: flex;
  gap: 20rpx;
}

.contact-btn {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}

.copy-btn {
  background-color: #FF6B35;
  color: #fff;
}

.call-btn {
  background-color: #4caf50;
  color: #fff;
}

.actions {
  margin-top: 40rpx;
  padding-bottom: 40rpx;
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.edit-btn {
  background-color: #FF6B35;
  color: #fff;
}

.on-btn {
  background-color: #4caf50;
  color: #fff;
}

.off-btn {
  background-color: #ff9800;
  color: #fff;
}

.delete-btn {
  background-color: #f44336;
  color: #fff;
}

.report-btn {
  background-color: #999;
  color: #fff;
}

.loading {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
}
