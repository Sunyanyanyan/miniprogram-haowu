<view class="container" wx:if="{{!loading && item}}">
  <swiper class="image-swiper" indicator-dots="{{item.images.length > 1}}" autoplay="{{true}}" interval="{{3000}}" duration="{{500}}" circular="{{true}}">
    <swiper-item wx:for="{{item.images}}" wx:key="*this">
      <image 
        class="detail-image" 
        src="{{item}}" 
        mode="aspectFill"
        data-url="{{item}}"
        bindtap="previewImage"
      ></image>
    </swiper-item>
  </swiper>

  <view class="info-section">
    <view class="title-row">
      <view class="title">{{item.title}}</view>
      <view class="share-btn" bindtap="showShareMenu">
        <text class="share-icon">📤</text>
        <text class="share-text">分享</text>
      </view>
    </view>
    <view class="tag-wrap" wx:if="{{item.tag}}">
      <view class="item-tag">{{item.tag}}</view>
    </view>
    <view class="expire-tip" wx:if="{{expireText}}">
      <text class="expire-icon">⏰</text>
      <text class="expire-text">{{expireText}}</text>
    </view>
    <view class="info-row" wx:if="{{item.value}}">
      <text class="info-label">好物值</text>
      <text class="info-value highlight">{{item.value}}</text>
    </view>
  </view>

  <view class="desc-section">
    <view class="section-title">描述</view>
    <text class="desc-text">{{item.desc}}</text>
  </view>

  <view class="contact-section">
    <view class="section-title">用户唯一标识</view>
    <view wx:if="{{!showContact}}" class="contact-hidden" bindtap="showContact">
      <text>点击查看信息</text>
    </view>
    <view wx:else class="contact-info">
      <text class="contact-text">{{item.contact}}</text>
      <view class="contact-actions">
        <view class="contact-btn" bindtap="copyContact">复制</view>
      </view>
    </view>
  </view>

  <view class="actions" wx:if="{{fromMine && isOwner}}">
    <button class="action-btn edit-btn" bindtap="goToEdit">编辑</button>
    <button class="action-btn {{item.status === 'on' ? 'off-btn' : 'on-btn'}}" bindtap="toggleStatus">
      {{item.status === 'on' ? '隐藏' : '展示'}}
    </button>
    <button class="action-btn delete-btn" bindtap="deleteItem">删除</button>
  </view>
</view>

<view class="loading" wx:if="{{loading}}">
  <text>加载中...</text>
</view>

<canvas canvas-id="shareCanvas" class="share-canvas" style="width: 300px; height: 400px; position: fixed; left: -9999px; top: -9999px;"></canvas>

<view class="share-modal" wx:if="{{showShareModal}}" bindtap="hideShareModal">
  <view class="share-modal-content" catchtap="preventClose">
    <view class="share-modal-title">分享好物</view>
    <image class="share-preview" src="{{shareImagePath}}" mode="widthFix" wx:if="{{shareImagePath}}"></image>
    <view class="share-modal-tip">长按图片保存到相册，可发朋友圈</view>
    <button class="save-btn" bindtap="saveToAlbum">保存到相册</button>
  </view>
</view>
