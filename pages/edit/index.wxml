<view class="container" wx:if="{{!loading}}">
  <view class="form-section">
    <view class="section-title">图片上传</view>
    <view class="section-tip">最多上传3张图片，支持从相册选择或拍照</view>
    <view class="image-upload">
      <view class="image-item" wx:for="{{images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill"></image>
        <view class="delete-btn" data-index="{{index}}" bindtap="deleteImage">×</view>
      </view>
      <view class="add-image" wx:if="{{images.length < 3}}" bindtap="chooseImage">
        <text class="add-icon">+</text>
        <text class="add-text">添加图片</text>
      </view>
    </view>
    <view class="image-count">
      <text>已上传 {{images.length}}/3 张</text>
    </view>
  </view>

  <view class="form-section">
    <view class="section-title">好物信息</view>
    
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">标签</text>
        <text class="label-required">*</text>
      </view>
      <picker 
        mode="selector" 
        range="{{tags}}" 
        value="{{tagIndex}}"
        bindchange="onTagChange"
      >
        <view class="form-picker">
          <text wx:if="{{tagIndex >= 0}}">{{tags[tagIndex]}}</text>
          <text wx:else class="input-placeholder">请选择标签</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
    
    <view class="form-item">
      <view class="form-label">
        <text class="label-text">标题</text>
        <text class="label-required">*</text>
      </view>
      <input 
        class="form-input" 
        placeholder="请输入好物标题（50字以内）" 
        value="{{title}}"
        bindinput="onTitleInput"
        maxlength="50"
        placeholder-class="input-placeholder"
      />
      <view class="input-count">
        <text>{{title.length}}/50</text>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="label-text">好物值</text>
        <text class="label-required">*</text>
      </view>
      <input 
        class="form-input" 
        type="digit"
        placeholder="请输入好物值，如：100、99.50" 
        value="{{value}}"
        bindinput="onValueInput"
        placeholder-class="input-placeholder"
      />
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="label-text">详细描述</text>
        <text class="label-required">*</text>
      </view>
      <textarea 
        class="form-textarea" 
        placeholder="请详细描述好物的情况，如新旧程度、使用时长等（500字以内）" 
        value="{{desc}}"
        bindinput="onDescInput"
        maxlength="500"
        placeholder-class="input-placeholder"
      />
      <view class="input-count">
        <text>{{desc.length}}/500</text>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">
        <text class="label-text">联系信息</text>
        <text class="label-required">*</text>
      </view>
      <input 
        class="form-input" 
        placeholder="请输入手机号或微信号（50字以内）" 
        value="{{contact}}"
        bindinput="onContactInput"
        maxlength="50"
        placeholder-class="input-placeholder"
      />
      <view class="input-count">
        <text>{{contact.length}}/50</text>
      </view>
    </view>
  </view>

  <view class="submit-section">
    <button class="cancel-btn" bindtap="cancel">取消</button>
    <button class="submit-btn" bindtap="submit" disabled="{{submitting}}">
      <text wx:if="{{!submitting}}">保存</text>
      <text wx:else>保存中...</text>
    </button>
  </view>
</view>

<view class="loading" wx:if="{{loading}}">
  <text>加载中...</text>
</view>
