.container {
  padding: 0;
  background-color: #F8F9FB;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.form-section {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  position: relative;
  z-index: 1;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.section-tip {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.image-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.add-image {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #F8F9FB;
}

.add-icon {
  font-size: 60rpx;
  color: #ccc;
  line-height: 1;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 24rpx;
  color: #999;
}

.image-count {
  font-size: 24rpx;
  color: #999;
  text-align: right;
}

.form-item {
  margin-bottom: 32rpx;
  position: relative;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.label-required {
  color: #f44336;
  font-size: 28rpx;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  transition: all 0.3s ease;
  background-color: #F8F9FB;
  line-height: 88rpx;
}

.form-input:focus {
  border-color: #9B59B6;
  background-color: #fff;
  box-shadow: 0 0 0 4rpx rgba(155, 89, 182, 0.1);
}

.form-textarea {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  min-height: 200rpx;
  transition: all 0.3s ease;
  background-color: #F8F9FB;
}

.form-textarea:focus {
  border-color: #9B59B6;
  background-color: #fff;
  box-shadow: 0 0 0 4rpx rgba(155, 89, 182, 0.1);
}

.input-placeholder {
  color: #bbb;
  font-size: 26rpx;
}

.form-picker {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  background-color: #F8F9FB;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-placeholder {
  color: #bbb;
}

.picker-value {
  color: #333;
}

.picker-arrow {
  font-size: 20rpx;
  color: #9B59B6;
}

.input-count {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  margin-top: 8rpx;
}

.submit-section {
  margin: 40rpx 20rpx;
}

.submit-btns {
  display: flex;
  gap: 20rpx;
}

.cancel-btn {
  flex: 1;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 50rpx;
  padding: 32rpx 0;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.cancel-btn:active {
  background-color: #e0e0e0;
}

.submit-btn {
  flex: 1;
  background: linear-gradient(135deg, #9B59B6 0%, #8E44AD 100%);
  color: #fff;
  border-radius: 50rpx;
  padding: 32rpx 0;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(155, 89, 182, 0.3);
  transition: all 0.3s ease;
}

.submit-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(155, 89, 182, 0.3);
}

.submit-btn[disabled] {
  background-color: #ccc;
  box-shadow: none;
}

.submit-tip {
  text-align: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.tag-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.tag-modal-content {
  width: 100%;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
}

.tag-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.tag-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tag-option {
  width: calc(33.33% - 14rpx);
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  background-color: #F8F9FB;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.tag-option.active {
  background: linear-gradient(135deg, #9B59B6 0%, #8E44AD 100%);
  color: #fff;
  border-color: #9B59B6;
}

.expire-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.expire-option {
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #F8F9FB;
  border-radius: 8rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.expire-option.active {
  background: linear-gradient(135deg, #9B59B6 0%, #8E44AD 100%);
  color: #fff;
  border-color: #9B59B6;
}

.expire-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}
