.container {
  padding: 0;
  background-color: #F8F9FB;
  min-height: 100vh;
  padding-bottom: 20rpx;
}

.search-section {
  padding: 20rpx 30rpx;
  background-color: #fff;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #F8F9FB;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-input::placeholder {
  color: #999;
}

.search-clear {
  width: 36rpx;
  height: 36rpx;
  background-color: #ccc;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
}

.tags-scroll {
  white-space: nowrap;
  padding: 20rpx 0;
  background-color: #fff;
}

.tags-list {
  display: inline-flex;
  padding: 0 30rpx;
}

.tag-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  background-color: #F8F9FB;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s ease;
}

.tag-item.active {
  background: linear-gradient(135deg, #9B59B6 0%, #8E44AD 100%);
  color: #fff;
}

.waterfall {
  display: flex;
  padding: 0 15rpx;
  gap: 15rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.item-card {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.item-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.item-card.expired {
  opacity: 0.5;
}

.card-image-wrap {
  position: relative;
  width: 100%;
  height: 300rpx;
}

.card-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  background-color: #f5f5f5;
  display: block;
}

.card-image.placeholder {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 24rpx;
}

.urgent-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: linear-gradient(135deg, #FF6B35 0%, #FF8C42 100%);
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 53, 0.3);
}

.expired-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.card-content {
  padding: 20rpx;
}

.card-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-value {
  font-size: 28rpx;
  color: #9B59B6;
  font-weight: 600;
}

.card-remain {
  font-size: 22rpx;
  color: #ff6b35;
  background-color: #fff3e0;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.card-expire {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  display: block;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #9B59B6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

.loading-spinner.small {
  width: 40rpx;
  height: 40rpx;
  border-width: 3rpx;
  margin-bottom: 12rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
  gap: 12rpx;
}

.no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #ccc;
  font-size: 26rpx;
}

.error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.retry-btn {
  background: linear-gradient(135deg, #9B59B6 0%, #8E44AD 100%);
  color: #fff;
  border-radius: 40rpx;
  padding: 16rpx 50rpx;
  font-size: 28rpx;
  border: none;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
}
