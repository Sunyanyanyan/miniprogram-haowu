<view class="container">
  <view class="search-section">
    <view class="search-bar">
      <input 
        class="search-input" 
        placeholder="搜索闲置好物" 
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
      <view class="search-clear" wx:if="{{keyword}}" bindtap="clearSearch">×</view>
    </view>
  </view>

  <scroll-view class="tags-scroll" scroll-x="{{true}}">
    <view class="tags-list">
      <view 
        class="tag-item {{currentTag === item ? 'active' : ''}}" 
        wx:for="{{tags}}" 
        wx:key="*this"
        data-tag="{{item}}"
        bindtap="onTagTap"
      >
        {{item}}
      </view>
    </view>
  </scroll-view>

  <view class="items-grid" wx:if="{{items.length > 0}}">
    <view 
      class="item-card" 
      wx:for="{{items}}" 
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="goToDetail"
    >
      <view class="image-wrap">
        <image 
          wx:if="{{item.images && item.images.length > 0}}"
          class="item-image" 
          src="{{item.images[0]}}" 
          mode="aspectFill"
          lazy-load="{{true}}"
          binderror="onImageError"
          data-index="{{index}}"
        ></image>
        <view wx:else class="item-image placeholder">
          <text>暂无图片</text>
        </view>
      </view>
      <view class="item-info">
        <text class="item-title">{{item.title}}</text>
        <text class="item-value" wx:if="{{item.value}}">好物值： {{item.value}}</text>
      </view>
    </view>
  </view>

  <view class="loading" wx:if="{{loading && items.length === 0}}">
    <text>加载中...</text>
  </view>

  <view class="loading" wx:if="{{loading && items.length > 0}}">
    <text>加载更多...</text>
  </view>

  <view class="no-more" wx:if="{{!hasMore && items.length > 0}}">
    <text>没有更多了</text>
  </view>

  <view class="error" wx:if="{{error && items.length === 0}}">
    <text class="error-text">{{errorMsg}}</text>
    <button class="retry-btn" bindtap="onRetry">重试</button>
  </view>

  <view class="empty" wx:if="{{!loading && !error && items.length === 0}}">
    <text class="empty-text">暂无好物</text>
    <text class="empty-tip">快去登记你的闲置好物吧</text>
  </view>
</view>
