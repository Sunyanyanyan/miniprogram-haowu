<view class="container">
  <view class="search-bar" bindtap="onSearch">
    <text class="search-text">搜索闲置物品</text>
  </view>

  <view class="items-grid" wx:if="{{items.length > 0}}">
    <view 
      class="item-card" 
      wx:for="{{items}}" 
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="goToDetail"
    >
      <image class="item-image" src="{{item.images[0]}}" mode="aspectFill"></image>
      <view class="item-info">
        <text class="item-title">{{item.title}}</text>
        <text class="item-time">{{item.createdAt}}</text>
      </view>
    </view>
  </view>

  <view class="loading" wx:if="{{loading && items.length === 0}}">
    <text>加载中...</text>
  </view>

  <view class="loading" wx:if="{{loading && items.length > 0}}">
    <text>加载更多...</text>
  </view>

  <view class="no-more" wx:if="{{!hasMore && items.length > 0}}">
    <text>没有更多了</text>
  </view>

  <view class="error" wx:if="{{error && items.length === 0}}">
    <text class="error-text">{{errorMsg}}</text>
    <button class="retry-btn" bindtap="onRetry">重试</button>
  </view>

  <view class="empty" wx:if="{{!loading && !error && items.length === 0}}">
    <text class="empty-text">暂无物品</text>
    <text class="empty-tip">快去发布你的闲置物品吧</text>
  </view>
</view>
