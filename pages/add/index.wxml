<view class="container">
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <block wx:if="{{!loading}}">
    <view class="form-section">
      <view class="section-title">上传图片</view>
      <view class="section-tip">最多上传3张图片，支持从相册选择或拍照</view>
      <view class="image-upload">
        <view class="image-item" wx:for="{{images}}" wx:key="*this">
          <image src="{{item}}" mode="aspectFill"></image>
          <view class="delete-btn" data-index="{{index}}" bindtap="deleteImage">×</view>
        </view>
        <view class="add-image" wx:if="{{images.length < 3}}" bindtap="chooseImage">
          <text class="add-icon">+</text>
          <text class="add-text">上传图片</text>
        </view>
      </view>
      <view class="image-count">
        <text>已上传 {{images.length}}/3 张</text>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">信息详情</view>
      
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">标签</text>
          <text class="label-required">*</text>
        </view>
        <view class="form-picker" bindtap="showTagPicker">
          <text class="{{tagIndex < 0 ? 'picker-placeholder' : 'picker-value'}}">{{tagIndex < 0 ? '请选择标签' : tags[tagIndex]}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </view>
      
      <view class="form-item">
        <view class="form-label">
          <text class="label-text">名称</text>
          <text class="label-required">*</text>
        </view>
        <input 
          class="form-input" 
          placeholder="请输入名称（50字以内）" 
          value="{{title}}"
          bindinput="onTitleInput"
          maxlength="50"
          placeholder-class="input-placeholder"
        />
        <view class="input-count">
          <text>{{title.length}}/50</text>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">
          <text class="label-text">好物值</text>
          <text class="label-required">*</text>
        </view>
        <input 
          class="form-input" 
          type="digit"
          placeholder="请输入好物值" 
          value="{{value}}"
          bindinput="onValueInput"
          placeholder-class="input-placeholder"
        />
      </view>

      <view class="form-item">
        <view class="form-label">
          <text class="label-text">描述</text>
          <text class="label-required">*</text>
        </view>
        <textarea 
          class="form-textarea" 
          placeholder="请输入描述（500字以内）" 
          value="{{desc}}"
          bindinput="onDescInput"
          maxlength="500"
          placeholder-class="input-placeholder"
        />
        <view class="input-count">
          <text>{{desc.length}}/500</text>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">
          <text class="label-text">用户唯一标识</text>
          <text class="label-required">*</text>
        </view>
        <input 
          class="form-input" 
          placeholder="请输入您的平台ID（50字以内）" 
          value="{{contact}}"
          bindinput="onContactInput"
          maxlength="50"
          placeholder-class="input-placeholder"
        />
        <view class="input-count">
          <text>{{contact.length}}/50</text>
        </view>
      </view>

      <view class="form-item">
        <view class="form-label">
          <text class="label-text">时效设置</text>
        </view>
        <view class="expire-options">
          <view 
            class="expire-option {{expireIndex === index ? 'active' : ''}}" 
            wx:for="{{expireOptions}}" 
            wx:key="value"
            data-index="{{index}}"
            bindtap="selectExpire"
          >
            {{item.label}}
          </view>
        </view>
        <view class="expire-tip">
          <text>到期后将自动隐藏，不再展示在首页</text>
        </view>
      </view>
    </view>

    <view class="submit-section">
      <button class="submit-btn" bindtap="submit" disabled="{{submitting}}">
        <text wx:if="{{!submitting}}">录入</text>
        <text wx:else>录入中...</text>
      </button>
      <view class="submit-tip">
        <text>录入后将展示在首页，其他用户可以查看</text>
      </view>
    </view>
  </block>
</view>

<view class="tag-modal" wx:if="{{showTagModal}}" bindtap="hideTagPicker">
  <view class="tag-modal-content" catchtap="preventClose">
    <view class="tag-modal-title">选择标签</view>
    <view class="tag-options">
      <view 
        class="tag-option {{tagIndex === index ? 'active' : ''}}" 
        wx:for="{{tags}}" 
        wx:key="*this"
        data-index="{{index}}"
        bindtap="selectTag"
      >
        {{item}}
      </view>
    </view>
  </view>
</view>
