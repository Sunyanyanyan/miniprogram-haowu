<view class="container">
  <view class="stats-section">
    <view class="stat-item">
      <text class="stat-num">{{stats.userCount}}</text>
      <text class="stat-label">用户数</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.total}}</text>
      <text class="stat-label">好物总数</text>
    </view>
    <view class="stat-item">
      <text class="stat-num on">{{stats.on}}</text>
      <text class="stat-label">展示中</text>
    </view>
    <view class="stat-item">
      <text class="stat-num off">{{stats.off}}</text>
      <text class="stat-label">已隐藏</text>
    </view>
  </view>

  <view class="analytics-section">
    <view class="section-title">页面浏览统计</view>
    <view class="analytics-grid">
      <view class="analytics-item">
        <text class="analytics-label">首页浏览</text>
        <text class="analytics-num">{{analytics.pageViews.home || 0}}</text>
      </view>
      <view class="analytics-item">
        <text class="analytics-label">登记页浏览</text>
        <text class="analytics-num">{{analytics.pageViews.add || 0}}</text>
      </view>
      <view class="analytics-item">
        <text class="analytics-label">我的页浏览</text>
        <text class="analytics-num">{{analytics.pageViews.mine || 0}}</text>
      </view>
      <view class="analytics-item">
        <text class="analytics-label">详情页浏览</text>
        <text class="analytics-num">{{analytics.pageViews.detail || 0}}</text>
      </view>
    </view>
  </view>

  <view class="items-section">
    <view class="section-title">所有好物</view>

    <view class="item-list">
      <view class="item-card" wx:for="{{items}}" wx:key="_id">
        <view class="item-main">
          <image class="item-image" src="{{item.images[0]}}" mode="aspectFill"></image>
          <view class="item-info">
            <text class="item-title">{{item.title}}</text>
            <text class="item-time">{{item.createdAt}}</text>
            <text class="item-status {{item.status === 'on' ? 'on' : 'off'}}">
              {{item.status === 'on' ? '展示中' : '已隐藏'}}
            </text>
          </view>
        </view>
        <view class="item-actions">
          <view 
            class="action-btn" 
            data-id="{{item._id}}" 
            data-status="{{item.status}}"
            bindtap="toggleStatus"
          >
            {{item.status === 'on' ? '隐藏' : '展示'}}
          </view>
          <view class="action-btn delete" data-id="{{item._id}}" bindtap="deleteItem">
            删除
          </view>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{!loading && items.length === 0}}">
      <text class="empty-text">暂无好物</text>
    </view>
  </view>
</view>
