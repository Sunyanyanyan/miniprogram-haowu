.container {
  padding: 20rpx;
  background: linear-gradient(135deg, #f5f5f5 0%, #ffffff 100%);
  min-height: 100vh;
}

.stats-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 25%;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.stat-num.on {
  color: #4caf50;
}

.stat-num.off {
  color: #f44336;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.items-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.item-card {
  border-bottom: 2rpx solid #f5f5f5;
  padding: 20rpx 0;
}

.item-main {
  display: flex;
  align-items: center;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  background-color: #f0f0f0;
}

.item-info {
  flex: 1;
}

.item-title {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.item-time {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}

.item-status {
  display: inline-block;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.item-status.on {
  background-color: #e8f5e9;
  color: #4caf50;
}

.item-status.off {
  background-color: #ffebee;
  color: #f44336;
}

.item-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 10rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 4rpx;
  background-color: #f5f5f5;
  color: #666;
}

.action-btn.delete {
  background-color: #ffebee;
  color: #f44336;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
}

.analytics-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.analytics-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 20rpx;
}

.analytics-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  box-sizing: border-box;
}

.analytics-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.analytics-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}
